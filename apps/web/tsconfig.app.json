{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite-plus/client"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@ogame-agent/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src"]
}
